{
    "name": "k8s-admin-agent",
    "version": "1.0.0",
    "description": "AI-powered Kubernetes cluster administrator using MCP Server",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "deployment": {
        "port": 8000,
        "env": {
            "MCP_SERVER_URL": "http://k8s-mcp-server:8080",
            "HOST": "0.0.0.0",
            "PORT": "8000"
        },
        "resources": {
            "requests": {
                "memory": "256Mi",
                "cpu": "250m"
            },
            "limits": {
                "memory": "512Mi",
                "cpu": "500m"
            }
        }
    }
}